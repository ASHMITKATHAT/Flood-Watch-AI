# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-here
DEBUG=True
PORT=5000

# API Keys
OPENWEATHER_API_KEY=your_openweather_api_key_here
ISRO_LULC_API_KEY=your_isro_api_key_here
NASA_API_KEY=your_nasa_api_key_here

# SMS Configuration (Twilio/TextLocal)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890
TEXTLOCAL_API_KEY=your_textlocal_key
TEXTLOCAL_SENDER=EQUINOX

# Database (Optional)
DATABASE_URL=sqlite:///equinox.db

# Logging
LOG_LEVEL=INFO

# Cache
CACHE_TIMEOUT_NASA=1800
CACHE_TIMEOUT_WEATHER=600
CACHE_TIMEOUT_TERRAIN=86400

# Performance
MAX_WORKERS=4
BATCH_SIZE=1000